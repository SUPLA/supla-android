<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto">

  <LinearLayout
    android:id="@+id/list_item_thermostat_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/distance_default"
    android:gravity="center_vertical"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <androidx.appcompat.widget.AppCompatImageView
      android:id="@+id/list_item_icon"
      android:layout_width="@dimen/channel_img_width"
      android:layout_height="@dimen/channel_img_height" />

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="vertical">

      <TextView
        android:id="@+id/list_item_value"
        style="@style/AppTheme.TextAppearance.ListItemValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/distance_tiny" />

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatImageView
          android:id="@+id/list_item_indicator"
          android:layout_width="12dp"
          android:layout_height="12dp"
          android:layout_marginStart="@dimen/distance_tiny" />

        <TextView
          android:id="@+id/list_item_subvalue"
          style="@style/AppTheme.TextAppearance.Body2"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="4dp" />
      </LinearLayout>

    </LinearLayout>

  </LinearLayout>
</merge>